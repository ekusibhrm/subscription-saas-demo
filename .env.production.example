# Railway (or any container platform) 本番環境用の環境変数一覧。
# このファイル自体はコミット用のテンプレートであり、実際の値はRailwayの
# Variables画面に直接設定する(このファイルをコンテナに持ち込む必要はない)。
#
# 前提: Stripeは必ずテストモードのキー(pk_test_ / sk_test_)を使う。
#       本番用(live)キーは絶対に設定しない。

# --- App ---
APP_NAME="Subscription SaaS Demo"
APP_ENV=production
APP_DEBUG=false
# php artisan key:generate --show の出力をそのまま設定する(コンテナ内で都度生成しない)
APP_KEY=
# RailwayがサービスにアタッチしたドメインのHTTPS URL(例: https://xxxx.up.railway.app)
APP_URL=

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja

# --- Database ---
# Railway MySQLプラグインを追加した場合、"Variable Reference" 機能で
# そのプラグイン(仮にサービス名が"MySQL")の変数を参照する。
# 例: Railwayの本サービスのVariablesタブで下記のように設定する。
#   DB_CONNECTION=mysql
#   DB_HOST=${{MySQL.MYSQLHOST}}
#   DB_PORT=${{MySQL.MYSQLPORT}}
#   DB_DATABASE=${{MySQL.MYSQLDATABASE}}
#   DB_USERNAME=${{MySQL.MYSQLUSER}}
#   DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# もしくは1本のDSNでまとめて渡す場合(どちらか一方でよい):
#   DB_CONNECTION=mysql
#   DB_URL=${{MySQL.MYSQL_URL}}
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Session / Cache / Queue ---
# コンテナのローカルディスクは再デプロイのたびに消えるため、
# file/localではなくdatabaseドライバを使う(このアプリのデフォルトのまま)。
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Logging ---
# Railwayはstdout/stderrをそのままログとして収集するため、ファイルではなくstderrに出す。
LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Mail(デモではメール送信しないためlogのままで可) ---
MAIL_MAILER=log

# --- Stripe(必ずテストモードのキーのみ) ---
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
# Stripeダッシュボード(テストモード)の Webhooks > エンドポイントを追加 で発行される値。
# ローカルの `stripe listen` が発行するwhsecとは別物なので注意。
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
